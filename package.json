{
  "name": "jadeesttristekahoot",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"vite\" \"node --env-file=.env tsx server/index.ts\" 2>/dev/null || concurrently -n client,server -c cyan,magenta \"vite\" \"tsx --env-file=.env server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx --env-file=.env server/index.ts",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "db:init": "tsx --env-file=.env server/db-init.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "express": "^4.21.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "@neondatabase/serverless": "^0.10.4",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.5.5",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "tsx": "^4.19.0",
    "concurrently": "^9.0.1"
  }
}
